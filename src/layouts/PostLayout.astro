---
import BaseLayout from "./BaseLayout.astro";
import UserCardLayout from "./UserCardLayout.astro";

const { title, description, date, author } = Astro.props.data;
---

<BaseLayout>
  <article class="post-content">
    <section class="post">
      <h1>{title}</h1>
      <h2>{description}</h2>
      <UserCardLayout date={date} author={author} />
      <slot />
    </section>
  </article>
</BaseLayout>
